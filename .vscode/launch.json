{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Save Preprocessed",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/save_preprocessed.py",
            "args": [
                "-c",
                "config/backbone_full.yaml"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Run Preprocess Grid",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/run_preprocess_grid.py",
            "args": [
                "--grid",
                "config/preprocess_grid_corrected_1_10.yaml"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Grid: Run Preprocess Grid (Skip Existing)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/run_preprocess_grid.py",
            "args": [
                "--grid",
                "config/preprocess_grid.yaml"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Grid: Run Preprocess Grid (Only 11-13 Raw)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/run_preprocess_grid.py",
            "args": [
                "--grid",
                "config/preprocess_grid.yaml",
                "--only-ids",
                "11,12,13"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Grid: Run Preprocess Grid (Corrected 1-10)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/run_preprocess_grid.py",
            "args": [
                "--grid",
                "config/preprocess_grid_corrected_1_10.yaml"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Grid: Check Preprocessed Status",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/check_preprocessed_grid_status.py",
            "args": [
                "--grid",
                "config/preprocess_grid.yaml"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Grid: Check Preprocessed Status (Corrected 1-10)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/check_preprocessed_grid_status.py",
            "args": [
                "--grid",
                "config/preprocess_grid_corrected_1_10.yaml",
                "--preprocessed-dir",
                "output_corrected/preprocessed",
                "--out-csv",
                "output/eda/preprocessed_status/preprocess_grid_corrected_status.csv"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "EDA: Check Repeated Flights (Preprocessed Existing)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/check_preprocessed_repetitions.py",
            "args": [
                "--preprocessed-dir",
                "output/preprocessed",
                "--matched-glob",
                "matched_trajectories/matched_trajs_*.csv",
                "--id-start",
                "1",
                "--id-end",
                "10",
                "--window-minutes",
                "10"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Grid: Run Experiment Grid (Prompt)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/run_experiment_grid.py",
            "args": [
                "--grid",
                "experiments/${input:experimentGridFile}"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Plot Experiment Results",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/plot_experiment_results.py",
            "args": [
                "${input:experimentName}"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Plot Backbone Tracks (Lat/Lon)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/plot_backbone_tracks.py",
            "args": [
                "--experiment",
                "${input:experimentName}",
                "--arrival-scheme",
                "median"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Plot Backbone Tracks (Doc29 7-Track)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/plot_backbone_tracks.py",
            "args": [
                "--experiment",
                "${input:experimentName}",
                "--arrival-scheme",
                "seven"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Plot Clustered Flows (Lat/Lon)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/plot_exp_latlon_flows.py",
            "args": [
                "${input:experimentName}",
                "--flows",
                "Start_09L",
                "Start_09R",
                "Start_27L",
                "Start_27R",
                "--max-flights-per-cluster",
                "200"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Plot: Clustered Flows + Noise (Lat/Lon)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/plot_exp_latlon_flows.py",
            "args": [
                "${input:experimentName}",
                "--flows",
                "Start_09L",
                "Start_09R",
                "Start_27L",
                "Start_27R",
                "Landung_27L",
                "Landung_27R",
                "Landung_09L",
                "Landung_09R",
                "--max-flights-per-cluster",
                "300"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Plot: Clustered Flows (No Noise)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/plot_exp_latlon_flows.py",
            "args": [
                "${input:experimentName}",
                "--flows",
                "Start_09L",
                "Start_09R",
                "Start_27L",
                "Start_27R",
                "Landung_27L",
                "Landung_27R",
                "Landung_09L",
                "Landung_09R",
                "--max-flights-per-cluster",
                "250",
                "--exclude-noise"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Export KML (Experiment)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/export_experiment_kml.py",
            "args": [
                "--experiment",
                "${input:experimentName}",
                "--max-per-cluster",
                "200",
                "--include-noise",
                "--include-runways"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "EDA Raw Flight Lengths",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/eda_raw_lengths.py",
            "args": [
                "-c",
                "config/backbone_full.yaml",
                "--outdir",
                "output/eda/raw_lengths"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "EDA Flight Counts",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/eda_flight_counts.py",
            "args": [
                "-c",
                "config/backbone_full.yaml",
                "--outdir",
                "output/eda/flight_counts"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "EDA Combo: Lengths + Flight Counts",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/run_eda_combo.py",
            "args": [
                "-c",
                "config/backbone_full.yaml"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "EDA Monthly ADS-B (All Files)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/eda_adsb_monthly.py",
            "args": [
                "--input-dir",
                "data/adsb",
                "--outdir",
                "output/eda/adsb_monthly"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "EDA MP Repetition Summary (Preprocessed 1-10)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/summarize_mp_repetitions.py",
            "args": [
                "--reports-dir",
                "output/eda/mp_repetition_checks",
                "--id-start",
                "1",
                "--id-end",
                "10"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Doc29 Automation (Experiment)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/noise_simulation/run_doc29_experiment.py",
            "args": [
                "--experiment",
                "${input:doc29Experiment}",
                "--aircraft-types",
                "E170",
                "B738",
                "B38M",
                "A319",
                "A320",
                "A20N",
                "A321",
                "E190",
                "E75L",
                "E195",
                "--skip-existing"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Doc29 Ground Truth (Batched)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/noise_simulation/run_doc29_ground_truth.py",
            "args": [
                "--preprocessed",
                "${input:preprocessedCsv}",
                "--matched-dir",
                "matched_trajectories",
                "--output-root",
                "${input:groundTruthOut}",
                "--batch-size",
                "1000"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        }
        ,
        {
            "name": "Doc29 Compare Totals (Fair)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/noise_simulation/compare_experiment_totals.py",
            "args": [
                "--summary",
                "${input:summaryMseCsv}",
                "--out",
                "${input:totalsOut}",
                "--subtracks-weighting",
                "weighted"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        }
    ],
    "inputs": [
        {
            "id": "experimentGridFile",
            "type": "promptString",
            "description": "Experiment grid file name inside experiments/ (e.g., experiment_grid_051_070_dtw_frechet.yaml)",
            "default": "experiment_grid.yaml"
        },
        {
            "id": "experimentName",
            "type": "promptString",
            "description": "Experiment name (e.g., EXP77)",
            "default": "EXP77"
        },
        {
            "id": "doc29Experiment",
            "type": "promptString",
            "description": "Doc29 experiment folder name (e.g., EXP77)",
            "default": "EXP77"
        },
        {
            "id": "preprocessedCsv",
            "type": "promptString",
            "description": "Preprocessed CSV path",
            "default": "data/preprocessed/preprocessed_1.csv"
        },
        {
            "id": "groundTruthOut",
            "type": "promptString",
            "description": "Ground truth output folder",
            "default": "noise_simulation/results_ground_truth/preprocessed_1"
        },
        {
            "id": "summaryMseCsv",
            "type": "promptString",
            "description": "summary_mse.csv path",
            "default": "noise_simulation/results/EXP001/summary_mse.csv"
        },
        {
            "id": "totalsOut",
            "type": "promptString",
            "description": "Totals comparison output folder",
            "default": "noise_simulation/results/EXP001/aggregate_totals"
        }
    ]
}
