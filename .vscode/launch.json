{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Save Preprocessed",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/save_preprocessed.py",
            "args": [
                "-c",
                "config/backbone_full.yaml"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Run Preprocess Grid",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/run_preprocess_grid.py",
            "args": [
                "--grid",
                "config/preprocess_grid_corrected_1_10.yaml"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Grid: Run Preprocess Grid (Skip Existing)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/run_preprocess_grid.py",
            "args": [
                "--grid",
                "config/preprocess_grid.yaml"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Grid: Run Experiment Grid 051-070 DTW/Frechet",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/run_experiment_grid.py",
            "args": [
                "--grid",
                "experiments/experiment_grid_051_070_dtw_frechet.yaml"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Grid: Run EXP089-100 DTW Dense Pilot",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/run_experiment_grid.py",
            "args": [
                "--grid",
                "experiments/experiment_grid_089_100_dtw_dense.yaml"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Grid: Run EXP111-120 HDBSCAN DTW Tuning",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/run_experiment_grid.py",
            "args": [
                "--grid",
                "experiments/experiment_grid_111_120_hdbscan_dtw_tuning.yaml"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Grid: Run EXP121-126 HDBSCAN DTW Refine",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/run_experiment_grid.py",
            "args": [
                "--grid",
                "experiments/experiment_grid_121_126_hdbscan_dtw_refine.yaml"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Grid: Run Experiment Grid (Prompt)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/run_experiment_grid.py",
            "args": [
                "--grid",
                "experiments/${input:experimentGridFile}"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "DTW: Probe DBSCAN eps (Dense)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/probe_dtw_dbscan_eps.py",
            "args": [
                "--preprocessed",
                "${input:dtwProbePreprocessed}",
                "--sample-per-flow",
                "${input:dtwProbeSamplePerFlow}",
                "--min-samples",
                "8",
                "--candidate-k",
                "999999",
                "--dtw-window-size",
                "8"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "DTW: Rank Pilot + Promote EXP021-024",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/rank_dtw_pilot_and_promote.py",
            "args": [
                "--output-root",
                "output/experiments",
                "--exp-start",
                "89",
                "--exp-end",
                "100",
                "--outdir",
                "output/eda/dtw_dense_pilot_ranking",
                "--target-grid",
                "experiments/experiment_grid.yaml",
                "--apply-promotion"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Plot Experiment Results",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/plot_experiment_results.py",
            "args": [
                "${input:experimentName}"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Plot Backbone Tracks (Lat/Lon)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/plot_backbone_tracks.py",
            "args": [
                "--experiment",
                "${input:experimentName}",
                "--arrival-scheme",
                "${input:arrivalScheme}"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Plot Backbone Tracks (Doc29 7-Track)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/plot_backbone_tracks.py",
            "args": [
                "--experiment",
                "${input:experimentName}",
                "--arrival-scheme",
                "seven"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Plot Clustered Flows (Lat/Lon)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/plot_exp_latlon_flows.py",
            "args": [
                "${input:experimentName}",
                "--flows",
                "Start_09L",
                "Start_09R",
                "Start_27L",
                "Start_27R",
                "Landung_09L",
                "Landung_09R",
                "Landung_27L",
                "Landung_27R",
                "--max-flights-per-cluster",
                "200"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Plot: Clustered Flows + Noise (Lat/Lon)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/plot_exp_latlon_flows.py",
            "args": [
                "${input:experimentName}",
                "--flows",
                "Start_09L",
                "Start_09R",
                "Start_27L",
                "Start_27R",
                "Landung_27L",
                "Landung_27R",
                "Landung_09L",
                "Landung_09R",
                "--max-flights-per-cluster",
                "300"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Plot: Clustered Flows (No Noise)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/plot_exp_latlon_flows.py",
            "args": [
                "${input:experimentName}",
                "--flows",
                "Start_09L",
                "Start_09R",
                "Start_27L",
                "Start_27R",
                "Landung_27L",
                "Landung_27R",
                "Landung_09L",
                "Landung_09R",
                "--max-flights-per-cluster",
                "250",
                "--exclude-noise"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Export KML (Experiment)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/export_experiment_kml.py",
            "args": [
                "--experiment",
                "${input:experimentName}",
                "--max-per-cluster",
                "200",
                "--include-noise",
                "--include-runways"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "EDA Raw Flight Lengths",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/eda_raw_lengths.py",
            "args": [
                "-c",
                "config/backbone_full.yaml",
                "--outdir",
                "output/eda/raw_lengths"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "EDA Flight Counts",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/eda_flight_counts.py",
            "args": [
                "-c",
                "config/backbone_full.yaml",
                "--outdir",
                "output/eda/flight_counts"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "EDA Combo: Lengths + Flight Counts",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/run_eda_combo.py",
            "args": [
                "-c",
                "config/backbone_full.yaml"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "EDA Monthly ADS-B (All Files)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/eda_adsb_monthly.py",
            "args": [
                "--input-dir",
                "data/adsb",
                "--outdir",
                "output/eda/adsb_monthly"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "EDA Flow Speed Stats",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/eda_flow_speed_stats.py",
            "args": [
                "--preprocessed",
                "${input:flowSpeedPreprocessed}",
                "--sample-per-flow",
                "${input:flowSpeedSamplePerFlow}"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Debug: HDBSCAN Toy",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/hdbscan_toy_debug.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "justMyCode": false
        },
        {
            "name": "Doc29 Automation (Experiment)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/noise_simulation/run_doc29_experiment.py",
            "args": [
                "--experiment",
                "${input:doc29Experiment}",
                "--aircraft-types",
                "E170",
                "B738",
                "B38M",
                "A319",
                "A320",
                "A20N",
                "A321",
                "E190",
                "E75L",
                "E195",
                "--skip-existing"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Doc29 Ground Truth (Batched)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/noise_simulation/run_doc29_ground_truth.py",
            "args": [
                "--preprocessed",
                "${input:preprocessedCsv}",
                "--matched-dir",
                "matched_trajectories",
                "--output-root",
                "${input:groundTruthOut}",
                "--batch-size",
                "1000"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Demo: DTW Alignment for Two Flights",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/dtw_alignment_demo.py",
            "args": [
                "--preprocessed",
                "${input:dtwDemoPreprocessed}",
                "--flight-a",
                "${input:dtwDemoFlightA}",
                "--flight-b",
                "${input:dtwDemoFlightB}"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Demo: DTW Alignment (Random Sample IDs)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/dtw_alignment_demo.py",
            "args": [
                "--preprocessed",
                "${input:dtwDemoPreprocessed}",
                "--list-random",
                "20"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Demo: Frechet Distance for Two Flights",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/frechet_distance_demo.py",
            "args": [
                "--preprocessed",
                "${input:dtwDemoPreprocessed}",
                "--flight-a",
                "${input:dtwDemoFlightA}",
                "--flight-b",
                "${input:dtwDemoFlightB}"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Demo: Frechet (Random Sample IDs)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/frechet_distance_demo.py",
            "args": [
                "--preprocessed",
                "${input:dtwDemoPreprocessed}",
                "--list-random",
                "20"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        }
        ,
        {
            "name": "Doc29 Compare Totals (Fair)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/noise_simulation/compare_experiment_totals.py",
            "args": [
                "--summary",
                "${input:summaryMseCsv}",
                "--out",
                "${input:totalsOut}",
                "--subtracks-weighting",
                "weighted"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        }
    ],
    "inputs": [
        {
            "id": "experimentGridFile",
            "type": "promptString",
            "description": "Experiment grid file name inside experiments/ (e.g., experiment_grid_051_070_dtw_frechet.yaml)",
            "default": "experiment_grid.yaml"
        },
        {
            "id": "experimentName",
            "type": "promptString",
            "description": "Experiment name (e.g., EXP77)",
            "default": "EXP77"
        },
        {
            "id": "experimentGridPath",
            "type": "promptString",
            "description": "Experiment grid YAML path",
            "default": "experiments/experiment_grid_089_100_dtw_dense.yaml"
        },
        {
            "id": "arrivalScheme",
            "type": "pickString",
            "description": "Arrival plotting scheme",
            "options": [
                "median",
                "seven"
            ],
            "default": "median"
        },
        {
            "id": "doc29Experiment",
            "type": "promptString",
            "description": "Doc29 experiment folder name (e.g., EXP77)",
            "default": "EXP77"
        },
        {
            "id": "preprocessedCsv",
            "type": "promptString",
            "description": "Preprocessed CSV path",
            "default": "data/preprocessed/preprocessed_1.csv"
        },
        {
            "id": "flowSpeedPreprocessed",
            "type": "pickString",
            "description": "Preprocessed CSV for flow speed statistics",
            "options": [
                "output/preprocessed/preprocessed_1.csv | 36578 flights",
                "output/preprocessed/preprocessed_2.csv | 36578 flights",
                "output/preprocessed/preprocessed_3.csv | 36578 flights",
                "output/preprocessed/preprocessed_4.csv | 36578 flights",
                "output/preprocessed/preprocessed_5.csv | 36578 flights",
                "output/preprocessed/preprocessed_6.csv | 36578 flights",
                "output/preprocessed/preprocessed_7.csv | 36578 flights",
                "output/preprocessed/preprocessed_8.csv | 36578 flights",
                "output/preprocessed/preprocessed_9.csv | 36578 flights",
                "output/preprocessed/preprocessed_10.csv | 36578 flights",
                "output/preprocessed/preprocessed_11.csv | 36448 flights",
                "output/preprocessed/preprocessed_12.csv | 36448 flights"
            ],
            "default": "output/preprocessed/preprocessed_1.csv | 36578 flights"
        },
        {
            "id": "flowSpeedSamplePerFlow",
            "type": "pickString",
            "description": "Maximum sampled flights per flow",
            "options": [
                "500",
                "1000",
                "1500"
            ],
            "default": "1000"
        },
        {
            "id": "groundTruthOut",
            "type": "promptString",
            "description": "Ground truth output folder",
            "default": "noise_simulation/results_ground_truth/preprocessed_1"
        },
        {
            "id": "summaryMseCsv",
            "type": "promptString",
            "description": "summary_mse.csv path",
            "default": "noise_simulation/results/EXP001/summary_mse.csv"
        },
        {
            "id": "totalsOut",
            "type": "promptString",
            "description": "Totals comparison output folder",
            "default": "noise_simulation/results/EXP001/aggregate_totals"
        },
        {
            "id": "dtwDemoPreprocessed",
            "type": "promptString",
            "description": "Preprocessed CSV for DTW demo",
            "default": "output/preprocessed/preprocessed_1.csv"
        },
        {
            "id": "dtwProbePreprocessed",
            "type": "promptString",
            "description": "Preprocessed CSV for DTW DBSCAN eps probe",
            "default": "output/preprocessed/preprocessed_1.csv"
        },
        {
            "id": "dtwProbeSamplePerFlow",
            "type": "pickString",
            "description": "Sample size per flow for DTW DBSCAN eps probe",
            "options": [
                "100",
                "300",
                "900"
            ],
            "default": "900"
        },
        {
            "id": "dtwDemoFlightA",
            "type": "promptString",
            "description": "First flight_id for DTW demo",
            "default": "11"
        },
        {
            "id": "dtwDemoFlightB",
            "type": "promptString",
            "description": "Second flight_id for DTW demo",
            "default": "201"
        }
    ]
}
